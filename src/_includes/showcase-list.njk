<div class="py-8 grid grid-cols-2 md:grid-cols-4 justify-between gap-y-10">
    {% for skill in skillList %}
    <div class="flex flex-col justify-center items-center content-center text-center">
        <img class="w-12 h-auto" src="{{skill.iconUrl}}" alt="{{skill.description}}" />
        <h3>
            {% if skill.projectCount %}
                <a title="{{skill.description}}" aria-label="View {{skill.name}} projects" class="secondary bold hover:text-white pt-2" href="/projects?filter={{skill.tag}}">
                {{skill.name}}
                </a>
            {% else %}
                <span class="introduction bold">{{skill.name}}</span>
            {% endif %}
            </h3>
        {% if skill.experience %}
        <h4 class="leading-tight small">{{skill.experience}}
        {% endif %} 
        {% if skill.projectCount and skill.experience %} 
        | 
        {% endif %}
        <a href="/projects?filter={{skill.tag}}" class="secondary hover:text-white" aria-label="View {{skill.projectCount}} {{skill.name}} projects">
        <u class="bold">
            {{skill.projectCount}}
        </u>
        </a>
    </h4>
    </div>
    {% endfor %}
</div>