<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">

    {% set pageTitle = project.title or title %}
    <title>{{ pageTitle if pageTitle else metadata.title }}{% if pageTitle %} | {{ metadata.title }}{% endif %}</title>

    <meta name="description" content="{{ project.tagline or description or metadata.description }}" />
    <link rel="canonical" href="{{ metadata.canonical }}{{ page.url }}">

    <meta property="og:type" content="{{ project and 'article' or 'website'}}">
    <meta property="og:title" content="{{ pageTitle if pageTitle else metadata.title }}{% if pageTitle %} | {{ metadata.title }}{% endif %}">
    <meta property="og:site_name" content="{{metadata.title}}">
    <meta property="og:description" content="{{ project.tagline or description or metadata.description }}">
    <meta property="og:image" content="{{ metadata.canonical }}/{{ project.showcaseHeaderUrl or image or metadata.image }}">
    <meta property="og:url" content="{{ metadata.canonical }}{{ page.url }}">
    <meta property="og:see_also" content="https://www.linkedin.com/in/mateusz-kusionowicz">
    <meta property="og:see_also" content="https://github.com/TheMatiaz0">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ pageTitle if pageTitle else metadata.title }}{% if pageTitle %} | {{ metadata.title }}{% endif %}">
    <meta name="twitter:description" content="{{ project.tagline or description or metadata.description }}">
    <meta name="twitter:image" content="{{ metadata.canonical }}/{{ project.showcaseHeaderUrl or image or metadata.image }}">

    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="{{ 'apple-touch-icon.png' | url }}"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="{{ 'favicon-32x32.png' | url }}"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="{{ 'favicon-16x16.png' | url }}"
    />
    <link rel="manifest" href="{{ 'site.webmanifest' | url }}" />
    <link rel="stylesheet" href="{{ 'fonts.css' | url }}" />
    <link rel="stylesheet" href="{{ 'site.css' | url }}" />

    {% if css %}
      {% for link in css %}
        <link rel="stylesheet" href="{{link | url}}">
      {% endfor %}
    {% endif %}
  </head>

  <body>
    <div class="mx-auto max-w-[var(--site-width)] md:px-0 px-4">
    <header class="flex flex-wrap justify-center sm:justify-between left-0 right-0 mx-auto max-w-[var(--site-width)] fixed bg-[color:var(--background-color)] py-4 md:py-8">
      <div class="flex flex-wrap align-middle items-center content-center place-content-center gap-5">
        <img class="w-20 h-20" src="{{'logo.png' | url}}" alt="logo"> 
          <div class="introduction md:pb-0 pb-4">
            <a class="hover:text-white whitespace-nowrap" href="{{'/' | url}}">
              <h1 class="leading-9 text-xl md:text-3xl">{{header.name}}</h1>
              <small class="text-base">{{header.profession}}</small>
            </a>
          </div>
      </div>
      <div class="my-4">
        {% set btn = "btn-secondary" %}
        {% set socialColor = "secondary" %}
        {% include "social-media.njk" %}
      </div>
    </header>
    <main>
      {{ content | safe }}
    </main>
    </div>
    {% if page.url == '/' %}
      {% include "footer.njk" %}
    {% elif page.url.startsWith('/projects') %}
    <footer class="mt-8 pb-9 pt-8 bg-[color:var(--primary-color)] w-full">
      <section class="max-w-[var(--site-width)] left-0 right-0 mx-auto">
        <h2 class="whitespace-nowrap lg:text-start text-center">Is there more? 👀</h2>
        <div class="px-4">
        <p class="pb-3 pt-3 md:text-xl text-lg">Yup! You can also check out my <a href="https://thematiaz0.itch.io" class="bold hover:text-black" target="_blank" rel="noopener">Itch.io</a> page, where I post all of my gamejam projects (some may be unfinished or experiments).</p> 
        <div class="flex justify-center align-middle items-center">
            {% set btn = "btn-black" %}
            {% set socialColor = "black" %}
            {% include "social-media.njk" %}
        </div>
        </div>
      </section>
  </footer>
    {% endif %}
  </body>
</html>
